{% doc %}
  Renders the "Meet a Breeder" section with three breeder profiles.

  Displays a grid of three breeder cards with images and names/specialties.
  Each card has a gradient overlay at the bottom for text readability.

  @example
  {% render 'meet-a-breeder' %}
{% enddoc %}

<div class="text-center bg-bg-light pt-0">
  <h2
    class="inline-block bg-primary text-white font-titles text-center mx-auto mb-0 pt-0.5 px-4 text-5xl leading-tight"
    style="border-top-left-radius:.25em;border-top-right-radius:.25em;"
  >
    Meet a Breeder
  </h2>
</div>

<section id="meet-a-breeder" class="border-t-[0.65rem] border-t-primary">
  <div class="max-w-[var(--width-container-content)] mx-auto px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Travis & McKale -->
      <div class="relative aspect-square w-full overflow-hidden rounded-2xl border-b-[6px] border-[var(--color-primary)] shadow-md">
        <img
          src="https://cdn.shopify.com/s/files/1/0603/0471/9957/files/travis-mckale-puppy-breeders.webp?v=1775235549"
          alt="Travis and McKale, breeders of Beagles and Aussiedoodles"
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          width="600"
          height="600"
        >
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-6 flex items-end justify-center">
          <div class="text-white font-titles text-xl md:text-2xl text-center">Travis &amp; McKale: Beagles &amp; Aussiedoodles</div>
        </div>
      </div>

      <!-- Angie -->
      <div class="relative aspect-square w-full overflow-hidden rounded-2xl border-b-[6px] border-[var(--color-primary)] shadow-md">
        <img
          src="https://cdn.shopify.com/s/files/1/0603/0471/9957/files/angie-puppy-breeder.webp?v=1775235549"
          alt="Angie, breeder of French Bulldogs and Boston Terriers"
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          width="600"
          height="600"
        >
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-6 flex items-end justify-center">
          <div class="text-white font-titles text-xl md:text-2xl text-center">Angie: French Bulldogs &amp; Boston Terriers</div>
        </div>
      </div>

      <!-- Ashton -->
      <div class="relative aspect-square w-full overflow-hidden rounded-2xl border-b-[6px] border-[var(--color-primary)] shadow-md">
        <img
          src="https://cdn.shopify.com/s/files/1/0603/0471/9957/files/ashton-puppy-breeder.webp?v=1775235549"
          alt="Ashton, breeder of Poodles, Beagles and Dachshunds"
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          width="600"
          height="600"
        >
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-6 flex items-end justify-center">
          <div class="text-white font-titles text-xl md:text-2xl text-center">Ashton: Poodles, Beagles &amp; Dachshunds</div>
        </div>
      </div>
    </div>
  </div>
</section>
