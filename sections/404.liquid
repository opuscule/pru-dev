{% comment %}
  This section is used in the 404 template to render page shown when customers
  enter an invalid store URL.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/404
{% endcomment %}

{% stylesheet %}
  a {
    @apply text-primary-red;
  }
  
  .contact_us_sm svg {
    @apply transition-all duration-250;
  }
  
  .contact_us_sm:focus svg, .contact_us_sm:hover svg {
    @apply fill-primary-red;
  }
{% endstylesheet %}



<section class="bg-[var(--color-bg-light)] py-5">
   <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-8">
         <!-- column 1 of 2 -->
         <div class="lg:w-1/2">
            <div class="my-5 flex flex-col">
               <h1 class="text-[length:var(--headline1-font-size)] font-bold leading-[1] flex-wrap mb-4">We Didn't Find That Page!</h1>
               <p class="text-[color:var(--color-body-copy)] font-[family:var(--font-body)]">The page you are looking for doesn't exist or has been moved.</p>
            </div>
            <div class="mt-4 mb-3 flex gap-4">
               <div class="flex-shrink-0">
                  <a href="https://www.instagram.com/puppysruswp/" target="_blank" title="Follow Puppys R Us on Instagram" rel="noopener nofollow" class="inline-flex justify-center items-center w-12 h-12 rounded-full bg-white/60 hover:bg-white/80 transition-colors">
                     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-[1.1rem] h-[1.1rem]">
                        <title>Follow Puppys R Us on Instagram</title>
