                     </svg>
                  </a>
               </div>
               <div class="flex-shrink-0">
                  <a href="https://www.youtube.com/channel/UCLUPFgsbDO7P5J-ryDJLkrw" target="_blank" title="Follow Puppys R Us on YouTube" rel="noopener nofollow" class="inline-flex justify-center items-center w-12 h-12 rounded-full bg-white/60 hover:bg-white/80 transition-colors">
                     <title>Follow Puppys R Us on YouTube</title>
                     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" class="w-[1.3rem] h-[1.3rem]">
                        <path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.321 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"></path>
                     </svg>
                  </a>
               </div>
            </div>
         </div>

         <!-- column 2 of 2 -->
         <div class="lg:w-5/12">
            <div class="my-5 flex flex-col">
               <h2 class="text-[color:var(--color-primary-red)] text-[length:var(--headline2-font-size)] font-bold leading-[1] mb-4">Call or Text</h2>
               <p class="text-[color:var(--color-body-copy)] font-[family:var(--font-body)]">
                  (844) SEE-PUPS or<!-- --> <a href="tel:+18447337877">(844) 733-7877</a>
               </p>
               <p class="text-[color:var(--color-body-copy)] font-[family:var(--font-body)]"><strong>Owners:</strong> Amy &amp; Sonny Smith</p>
               <p class="text-[color:var(--color-body-copy)] font-[family:var(--font-body)]"><strong>Puppys R Us, LLC.</strong></p>
               <p class="text-[color:var(--color-body-copy)] font-[family:var(--font-body)]"><strong>Mailing Address</strong><br>1404 Southern Hills #246<br>West Plains, MO 65775</p>
            </div>
         </div>
      </div>
   </div>
</section>
<section class="bg-[var(--color-bg-light)] pt-5" style="margin-bottom: -200px; padding-bottom: 100px;"></section>

