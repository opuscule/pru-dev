{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<style>
  /* Hide default details marker - no Tailwind equivalent */
  details summary::-webkit-details-marker,
  details summary::marker {
    display: none;
  }

  /* Accordion icon rotation on open */
  details .accordion-icon {
    transition: transform 0.3s ease-out;
  }

  details[open] .accordion-icon {
    transform: rotate(180deg);
  }

  /* Smooth accordion animation using grid */
  .accordion-content-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease-out;
  }

  .accordion-content-inner {
    overflow: hidden;
    min-height: 0;
  }

  /* Status complete state - toggled via JS */
  .status-complete {
    color: var(--color-primary);
  }

  /* Custom radio button styles */
  .custom-radio {
    appearance: none;
    -webkit-appearance: none;
    width: 28px;
    height: 28px;
    border: 3px solid #b1b1b1;
    border-radius: 50%;
    background: white;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .custom-radio:hover {
    border-color: var(--color-primary);
  }

  .custom-radio:checked {
    border-color: var(--color-primary);
  }

  .custom-radio:checked::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  /* Custom checkbox styles */
  .custom-checkbox {
    appearance: none;
    -webkit-appearance: none;
    width: 28px;
    height: 28px;
    border: 3px solid #b1b1b1;
    border-radius: 8px;
    background: white;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .custom-checkbox:hover {
    border-color: var(--color-primary);
  }

  .custom-checkbox:checked {
    border-color: var(--color-primary);
    background: var(--color-primary);
  }

  .custom-checkbox:checked::after {
    content: '';
    position: absolute;
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(45deg);
    width: 8px;
    height: 14px;
    border: solid white;
    border-width: 0 3px 3px 0;
  }

  /* Clickable card styles */
  .selectable-card {
    cursor: pointer;
    transition: all 0.2s ease;
  }


</style>

<section class="bg-bg-extralight pt-16 pb-[200px] -mb-[200px]" data-cart-section>
  <h1 class="font-titles font-bold text-4xl sm:text-5xl md:text-6xl lg:text-7xl 2xl:text-8xl text-center">Order Summary</h1>
  <p class="text-center mt-2">You're securing this puppy—final details confirmed at checkout.</p>
  <div class="w-full px-4 mx-auto mt-8">
    <div class="max-w-[var(--width-container-content)] mx-auto">

      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-form">
        {% assign delivery_product_ids = '7322490765397,7322488569941,7319932797013,7237943296085' | split: ',' %}
        {% assign delivery_subtotal = 0 %}
        {% assign has_visible_items = false %}
        {% for item in cart.items %}
          {% assign item_product_id = item.product.id | append: '' %}
          {% if delivery_product_ids contains item_product_id %}
            {% assign delivery_subtotal = delivery_subtotal | plus: item.final_line_price %}
          {% else %}
            {% assign has_visible_items = true %}
          {% endif %}
        {% endfor %}
        {% assign puppy_price = cart.items_subtotal_price | minus: delivery_subtotal %}
        {% assign is_deposit = false %}
        {% if cart.attributes['Payment Option'] == 'deposit' %}
          {% assign is_deposit = true %}
          {% comment %} Depo app already set the line item to the deposit amount, so puppy_price IS the deposit {% endcomment %}
          {% assign deposit_price = puppy_price %}
          {% comment %} Calculate remaining from the original product price {% endcomment %}
          {% assign original_price = 0 %}
          {% for item in cart.items %}
            {% assign item_product_id = item.product.id | append: '' %}
            {% unless delivery_product_ids contains item_product_id %}
              {% assign original_price = original_price | plus: item.product.price %}
            {% endunless %}
          {% endfor %}
          {% assign remaining_price = original_price | minus: deposit_price %}
        {% endif %}

        <div class="flex flex-wrap -mx-4">
          <div class="w-full lg:w-9/12 px-4">
            {% if cart.item_count == 0 or has_visible_items == false %}
              <p class="text-lg">Your cart is empty.</p>
            {% else %}
              {% for item in cart.items %}
                {% assign item_product_id = item.product.id | append: '' %}
                {% unless delivery_product_ids contains item_product_id %}
                  <!-- each cart item -->
                  
                  <a class="block bg-bg-light rounded-3xl overflow-hidden mb-6" href="{{ item.url }}" data-line="{{ item.key }}">
                    <div class="flex flex-col md:flex-row">

                      <!-- border-right 5px --color-primary -->
                      <div class="w-full md:w-1/4 bg-cover bg-no-repeat bg-center border-b-8 md:border-b-0 md:border-r-8 border-primary aspect-square" style="background-image:url({{ item.image | image_url: width: 425 }})">
                      </div>
                      <div class="w-full md:w-3/4 p-4 md:p-6 flex flex-col justify-between">
                        <div>
                          {% if item.product.metafields.custom.pruid %}
                            <pre class="px-2 text-[12px] bg-white inline-flex rounded-sm pt-[2px]">ID:{{ item.product.metafields.custom.pruid }}</pre>
                          {% endif %}
                          <div class="flex justify-between items-center">
                            <h3 class="text-5xl md:text-6xl font-semibold leading-tight tracking-tight mb-2 mt-1">{{- item.product.title -}}</h3>
                            <div>
                              {% if is_deposit %}
                                <span class="text-2xl md:text-3xl font-bold text-primary text-right">{{ deposit_price | money }}</span>
                                <div class="text-sm text-body-copy text-right mt-1">50% Deposit</div>
                              {% else %}
                                <span class="text-2xl md:text-3xl font-bold text-primary text-right">{{ item.final_line_price | money }}</span>
                              {% endif %}
                              <div class="flex items-center justify-end mt-0 md:mt-2">
                                <span class="text-sm text-body-copy text-right leading-none hover:text-red-500 transition-colors" onclick="event.preventDefault(); if(confirm('Remove this puppy from your cart?')) { window.location.href='/cart/change?id={{ item.key }}&quantity=0'; }">
                                  Remove
                                </span>
                              </div>
                            </div>
                          </div>
                          
                          <div class="text-lg font-medium text-body-copy mb-3">
                            {{ item.product.collections.first.title }}
                          </div>

                          {% comment %} Calculate age in weeks {% endcomment %}
                          {% assign dob_val = item.product.metafields.custom.dob.value %}
                          {% assign dob_ts = dob_val | date: '%s' | plus: 0 %}
                          {% assign now_ts = 'now' | date: '%s' | plus: 0 %}
                          {% assign diff_seconds = now_ts | minus: dob_ts %}
                          {% assign weeks_old = diff_seconds | divided_by: 604800 %}

                          {% comment %} Details grid {% endcomment %}
                          <div class="flex flex-wrap gap-x-8 gap-y-2 text-base md:text-lg mb-3">
                            {% if item.product.metafields.custom.sex %}
                              <div class="text-body-copy text-base leading-snug">
                                <span class="font-semibold">Sex:</span><br>{{ item.product.metafields.custom.sex }}
                              </div>
                            {% endif %}
                            
                            {% if item.product.metafields.custom.color %}
                              <div class="text-body-copy text-base max-w-52 md:max-w-40 leading-snug">
                                <span class="font-semibold">Color:</span><br>{{ item.product.metafields.custom.color }}
                              </div>
                            {% endif %}
                            
                            {% if weeks_old %}
                              <div class="text-body-copy text-base leading-snug">
                                <span class="font-semibold">Age:</span><br>{{ weeks_old | floor }} weeks
                              </div>
                            {% endif %}

                            {% if item.product.metafields.custom.size and item.product.metafields.custom.size != 13 %}
                              <div class="text-body-copy text-base leading-snug">
                                <span class="font-semibold">Size:</span><br>{{ item.product.metafields.custom.size }}
                              </div>
                            {% endif %}

                            {% if item.product.metafields.custom.variety %}
                              <div class="text-body-copy text-base leading-snug">
                                <span class="font-semibold">Variety:</span><br>{{ item.product.metafields.custom.variety }}
                              </div>
                            {% endif %}

                            {% if item.product.metafields.custom.generation %}
                              <div class="text-body-copy text-base leading-snug">
                                <span class="font-semibold">Generation:</span><br>{{ item.product.metafields.custom.generation }}
                              </div>
                            {% endif %}
                          </div>

                        </div>

                        {% comment %} Price at bottom {% endcomment %}
                        
                      </div>
                    </div>
                  </a>

                {% endunless %}
              {% endfor %}
            {% endif %}


            <!-- Delivery Options section -->
            {% if cart.item_count > 0 %}
              <details class="bg-bg-light rounded-3xl mt-6 overflow-hidden" id="delivery-accordion">
                <summary class="p-6 md:p-8 cursor-pointer list-none flex justify-between items-center">
                  <div>
                    <h3 class="m-0 font-titles font-bold text-4xl md:text-5xl text-body-copy">
                      Choose Delivery Option
                    </h3>
                    <div class="flex items-center gap-2 text-sm text-body-copy mt-2" id="delivery-status">
                      {% if cart.attributes['Delivery Method'] %}
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        <span>{{ cart.attributes['Delivery Method'] }}</span>
                      {% else %}
                        <span>Not selected</span>
                      {% endif %}
                    </div>
                  </div>
                  <svg class="accordion-icon w-6 h-6 transition-transform duration-300 ease-in-out shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </summary>
                <div class="accordion-content-wrapper">
                  <div class="accordion-content-inner">
                    <div class="p-6 md:p-8 pt-1 -mt-1">
                      <div id="delivery-options" class="space-y-4 pt-1">
                        
                        <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                          <div class="flex items-start gap-4">
                            <input
                              type="radio"
                              name="delivery"
                              value="I Will Decide Later"
                              class="custom-radio mt-1"
                              data-price="0"
                              data-product-id="7322490765397"
                              data-variant-id="42183040073813"
                            >
                            <div class="flex-1">
                              <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                                I Will Decide Later
                                <span class="text-base font-normal text-body-copy">(Free)</span>
                              </span>
                              <div class="text-sm text-body-copy mt-1">
                                Not quite sure? Talk with our team to get the best delivery option.
                              </div>
                            </div>
                          </div>
                        </label>

                        <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                          <div class="flex items-start gap-4">
                            <input
                              type="radio"
                              name="delivery"
                              value="Pick Up from Breeder"
                              class="custom-radio mt-1"
                              data-price="0"
                              data-product-id="7322488569941"
                              data-variant-id="42183037747285"
                            >
                            <div class="flex-1">
                              <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                                Pick Up from Breeder
                                <span class="text-base font-normal text-body-copy">(Free)</span>
                              </span>
                              <div class="text-sm text-body-copy mt-1">
                                Ideal for customers within driving distance of our breeders.
                              </div>
                            </div>
                          </div>
                        </label>

                        <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                          <div class="flex items-start gap-4">
                            <input
                              type="radio"
                              name="delivery"
                              value="Nearby Location"
                              class="custom-radio mt-1"
                              data-price="49900"
                              data-product-id="7319932797013"
                              data-variant-id="42173635264597"
                            >
                            <div class="flex-1">
                              <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                                Nearby Location
                                <span class="text-base font-normal text-body-copy">($499.00)</span>
                              </span>
                              <div class="text-sm text-body-copy mt-1">
                                A flexible option for buyers who want their puppy delivered close to home without needing full doorstep delivery.
                              </div>
                            </div>
                          </div>
                        </label>

                        <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                          <div class="flex items-start gap-4">
                            <input
                              type="radio"
                              name="delivery"
                              value="Home Delivery"
                              class="custom-radio mt-1"
                              data-price="59900"
                              data-product-id="7237943296085"
                              data-variant-id="41869989871701"
                            >
                            <div class="flex-1">
                              <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                                Home Delivery
                                <span class="text-base font-normal text-body-copy">($599.00)</span>
                              </span>
                              <div class="text-sm text-body-copy mt-1">
                                Perfect for those who prefer the convenience of having their new puppy delivered directly to their home.
                              </div>
                            </div>
                          </div>
                        </label>

                      </div>
                    </div>
                  </div>
                </div>
              </details>
            {% endif %}


            <!-- Required Agreements section -->
            <details class="bg-bg-light rounded-3xl mt-6 overflow-hidden" id="agreements-accordion">
              <summary class="p-6 md:p-8 cursor-pointer list-none flex justify-between items-center">
                <div>
                  <h3 class="m-0 font-titles font-bold text-4xl md:text-5xl text-body-copy">
                    Required Agreements
                  </h3>
                  <div class="flex items-center gap-2 text-sm text-body-copy mt-2" id="agreements-status">
                    <span>0 of 5 completed</span>
                  </div>
                </div>
                <svg class="accordion-icon w-6 h-6 transition-transform duration-300 ease-in-out shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="accordion-content-wrapper">
                <div class="accordion-content-inner">
                  <div class="p-6 md:p-8 pt-1 -mt-1">
              {% if cart.item_count > 0 %}
                <div class="space-y-3" data-terms>
                  <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                    <div class="flex items-start gap-4">
                      <input class="custom-checkbox mt-1" type="checkbox" id="certifyAge">
                      <div class="flex-1">
                        <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                          Health Guarantee Agreement
                        </span>
                        <div class="mt-1 text-sm text-body-copy">
                          I have read and agree to the Puppys R Us
                          <a
                            href="https://puppysrusdev.myshopify.com/pages/health-guarantee"
                            class="text-primary no-underline hover:underline"
                            onclick="event.stopPropagation();"
                            >Health Guarantee</a
                          >.
                        </div>
                      </div>
                    </div>
                  </label>

                  <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                    <div class="flex items-start gap-4">
                      <input class="custom-checkbox mt-1" type="checkbox" id="understandTerms">
                      <div class="flex-1">
                        <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                          Terms & Conditions / Purchase Agreement
                        </span>
                        <div class="text-sm mt-1 text-body-copy">
                          I confirm I am 18+ and agree to the Puppys R Us
                          <a
                            href="https://puppysrusdev.myshopify.com/pages/terms-of-service"
                            class="text-primary no-underline hover:underline"
                            onclick="event.stopPropagation();"
                            >Terms & Conditions</a
                          >.
                        </div>
                      </div>
                    </div>
                  </label>

                  <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                    <div class="flex items-start gap-4">
                      <input class="custom-checkbox mt-1" type="checkbox" id="acknowledgeAgreement">
                      <div class="flex-1">
                        <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                          Veterinary Care Acknowledgment
                        </span>
                        <div class="text-sm mt-1 text-body-copy">
                          I understand I must take my puppy to a licensed veterinarian within 72 hours of receiving
                          him/her.
                        </div>
                      </div>
                    </div>
                  </label>

                  <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                    <div class="flex items-start gap-4">
                      <input class="custom-checkbox mt-1" type="checkbox" id="acknowledgeAgreement1">
                      <div class="flex-1">
                        <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                          Transportation Agreement
                        </span>
                        <div class="text-sm mt-1 text-body-copy">
                          I understand my puppy will travel by safe, approved methods arranged by Puppys R Us, and I
                          will be contacted to confirm details.
                        </div>
                      </div>
                    </div>
                  </label>

                  <label class="selectable-card bg-white rounded-2xl p-6 md:p-8 block">
                    <div class="flex items-start gap-4">
                      <input class="custom-checkbox mt-1" type="checkbox" id="acknowledgeAgreement2">
                      <div class="flex-1">
                        <span class="text-lg font-medium cursor-pointer select-none block leading-tight">
                          Puppy Confirmation
                        </span>
                        <div class="text-sm mt-1 text-body-copy">I confirm I am purchasing the puppy listed in my order summary.</div>
                      </div>
                    </div>
                  </label>
                </div>
              {% endif %}
                  </div>
                </div>
              </div>
            </details>
          </div>

          <div class="w-full lg:w-3/12 px-4">
            <div class="bg-bg-light rounded-3xl mt-6 md:mt-0 p-6">
              <h4 class="font-titles font-bold text-4xl md:text-5xl lg:text-6xl text-body-copy mb-4">Total</h4>
              
              <ul class="list-none m-0 p-0 mb-4">
                <li class="flex justify-between items-center py-2">
                  <strong class="text-body-copy">Puppy Price</strong>
                  <span>{{ puppy_price | money }}</span>
                </li>

                {% if is_deposit %}
                  <li class="flex justify-between items-center py-2">
                    <strong class="text-body-copy">50% Deposit Due Today</strong>
                    <span class="text-primary font-bold">{{ deposit_price | money }}</span>
                  </li>
                  <li class="flex justify-between items-center py-2 text-sm text-body-copy">
                    <span>Remaining Balance</span>
                    <span>{{ remaining_price | money }}</span>
                  </li>
                {% endif %}
                
                <li class="flex justify-between items-center py-2">
                  <strong class="text-body-copy">Delivery Option</strong>
                  <span id="delivery-price-display">—</span>
                </li>

                {% if shop.taxes_included %}
                  <li class="text-sm italic border-b-0">Tax included. Shipping calculated at checkout.</li>
                {% else %}
                  <li class="text-sm italic border-b-0">Taxes calculated at checkout.</li>
                {% endif %}

                <li class="flex justify-between items-center py-2 border-b-0 text-2xl">
                  <strong class="text-body-copy font-titles">{% if is_deposit %}Due Today{% else %}Total{% endif %}</strong>
                  <span id="cart-total-display">{% if is_deposit %}{{ deposit_price | money }}{% else %}{{ cart.items_subtotal_price | money }}{% endif %}</span>
                </li>
              </ul>

              {% if cart.item_count > 0 %}
                <button
                  id="checkoutBtn"
                  type="button"
                  class="w-full py-3 px-9 text-white border-2 cursor-pointer mb-3 bg-primary border-primary rounded-full text-lg font-medium transition-all duration-200 disabled:bg-[#d7d5ce] disabled:border-[#d7d5ce] disabled:text-white hover:enabled:bg-primary-hover hover:enabled:border-primary-hover"
                  disabled
                  aria-disabled="true"
                >
                  {{ 'cart.checkout' | t }}
                </button>
                <div
                  id="checkout-text1"
                  class="text-center text-sm py-2 px-4 bg-white rounded-lg text-[var(--color-primary)] mb-4"
                >
                  Please accept all terms and select a shipping method
                </div>
                <div
                  id="delivery-selection-error"
                  class="hidden text-center text-sm py-2 px-4 bg-white rounded-lg text-red-600 mb-4"
                ></div>
              {% endif %}
            </div>
              <!-- Google Reviews Box -->
              <a href="https://maps.app.goo.gl/TCeBQGJhM78gmFr16" target="_blank" rel="noopener noreferrer" class="block mt-5 bg-white border border-gray-100 rounded-3xl p-6 shadow-sm hover:shadow-md transition-shadow no-underline">
                <div class="flex justify-center mb-3">
